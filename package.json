{
  "name": "pomodoro-timer",
  "version": "0.1.0",
  "description": "Pomodoro 타이머 웹 앱 - Vite + Vanilla JS",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
